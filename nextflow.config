params {

input_reads = null
single_end = false
outdir = "risultati"
samplesheet = "samplesheet.csv"
design = "condition"

multiqc_config = null

fasta       = null
gtf         = null
}

docker {
enabled = true
autoMounts = true
}

profiles {
test {includeConfig 'conf/test.config'}
}

process {
    withLabel: 'process_high' {
        cpus   = { Math.min( 12 * task.attempt, params.max_cpus as int ) }
        
        memory = { 
            def mem = 50.GB * task.attempt
            if (mem.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return mem
        }

        time   = { 6.h * task.attempt }
    }

    withLabel: 'process_low' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }
}
