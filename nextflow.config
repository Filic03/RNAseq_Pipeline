params {

input_reads = null
single_end = false
outdir = "risultati"

multiqc_config = null

fasta       = null
gtf         = null
}

docker {
enabled = true
autoMounts = true
}

profiles {
test {includeConfig 'conf/test.config'}
}

process {
    withLabel: 'process_high' {
        cpus   = { Math.min( 8 * task.attempt, params.max_cpus as int ) }
        
        memory = { 
            def mem = 16.GB * task.attempt
            if (mem.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return mem
        }

        time   = { 4.h * task.attempt }
    }
}
