params {
input_reads = null
single_end = false
outdir = "results"
samplesheet = "samplesheet.csv"
multiqc_config = null
fasta       = null
gtf         = null
max_cpus = 16
max_memory = '64.GB'
max_time = '24.h'
g = "gene_id"
strandedness = 0
enrichr_database = "GO_Biological_Process_2023,KEGG_2023_Human,Reactome_2022"
email = null
}
cleanup = true
docker {
enabled = true
autoMounts = true
}
profiles {
test {includeConfig 'conf/test.config'}
}
process {
    errorStrategy = {task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries = 2
    withLabel: 'process_high' {
        cpus   = { Math.min( 12 * task.attempt, params.max_cpus as int ) }
        memory = { 
            def mem = 50.GB * task.attempt
            if (mem.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return mem
        }
 time   = { 6.h * task.attempt }
    }
 withLabel: 'process_low' {
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }
}
